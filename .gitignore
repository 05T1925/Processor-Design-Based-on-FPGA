*.backup.log

# FPGA build artifacts
*.bit
*.bin
*.mcs
*.ltx
*.prm
*.dcp

# Vivado directories
.Xil/
*.cache/
*.runs/
*.sim/
*.hw/
*.ip_user_files/
*.gen/
*.srcs/
*.xpr

# Simulation outputs
sim/wave/*
!sim/wave/.gitkeep

# Generated reports kept out of git unless copied in intentionally
reports/vivado/*
!reports/vivado/.gitkeep
!reports/vivado/README.md

# Local reference material or large temporary board packages
install_packages/
reference_repos/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Python cache
__pycache__/
*.pyc

# Keep the full shared Vivado project directory for teammates who need a ready-to-open project.
!processor_fpga/
